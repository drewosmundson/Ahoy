[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/drewosmundson/ahoy
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
	vscode-merge-base = origin/main
[branch "refactorBranch"]
	remote = origin
	merge = refs/heads/refactorBranch
[branch "refactor"]
	remote = origin
	merge = refs/heads/refactor
	vscode-merge-base = origin/main
[pull]
	rebase = false
